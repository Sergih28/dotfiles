layout {
    pane_template name="default-with-time" {
        pane size=1 split_direction="vertical" {
            pane borderless=true {
                plugin location="zellij:tab-bar"
            }
        }
        pane size="100%" name="¯¬à"
        pane size=1 borderless=true {
            plugin location="zellij:status-bar"
        }
    }

    pane_template name="top-bar-with-time" {
        pane size=1 split_direction="vertical" borderless=true {
            plugin location="zellij:compact-bar"
        }
    }

    new_tab_template {
        top-bar-with-time
        pane size="100%" name="¯¬à"
        pane size=1 borderless=true {
            plugin location="zellij:status-bar"
        }
    }

    tab name="´äá" {
        top-bar-with-time
        pane size="100%" name="¯¬à"
        pane size=1 borderless=true {
            plugin location="zellij:status-bar"
        }
    }
    tab name="¯ù¥" {
        top-bar-with-time
        pane size="100%" command="spf" borderless=true
    }
    tab name="¯©ì" {
        top-bar-with-time
        pane stacked=true {
            pane name="¾▒×ƒ opencode" command="opencode" start_suspended=true cwd="~/ai-ask/"
            pane name="¾▒×ƒ opencode web" command="opencode" start_suspended=true cwd="~/ai-ask/" {
              args "web"
            }
            pane name="¾░å┐ cursor" command="cursor-agent" start_suspended=true cwd="~/ai-ask/"
            pane name="´Æë codex" command="codex" start_suspended=true cwd="~/ai-ask/"
            pane name="¾░ôÄ gemini" command="gemini" start_suspended=true cwd="~/ai-ask/"
            pane name="¯ê½ claude" command="claude" start_suspended=true cwd="~/ai-ask/"
        }
    }
    tab name="´ì»" {
        top-bar-with-time
        pane size="100%" command="nvim" borderless=true start_suspended=true
    }
    tab name="¾▒£┐" {
        top-bar-with-time
        pane stacked=true {
            pane name="¯£é lazygit" command="lazygit" start_suspended=true
            pane name="¯×░ lazydocker" command="lazydocker" start_suspended=true
            pane name="´çÇ lazysql" command="lazysql" start_suspended=true
        }
    }
    tab name="¯¬ä" {
        top-bar-with-time
        pane stacked=true {
            pane name="¾░ò« dashboard" command="gh" start_suspended=true {
              args "dash"
            }
            pane name="´ÆÜ notifications" command="gh" start_suspended=true {
              args "notify"
            }
            pane name="´äá playground"
        }
    }
    tab name="¾░îó" {
        top-bar-with-time
        pane stacked=true {
            pane name="´ÉÀ btm" command="btm" start_suspended=true
            pane name="¯»ú dysk" command="zsh"  start_suspended=true {
              args "-c" "clear; dysk"
            }
        }
    }
}

