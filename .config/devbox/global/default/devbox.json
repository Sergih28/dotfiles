{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.17.0/.schema/devbox.schema.json",
  "packages": {
    "taskwarrior3": "3.4.2",
    "timewarrior":  "latest",
    "atuin":        "latest"
  },
  "shell": {
    "init_hook": [
      "echo 'Welcome to devbox!' > /dev/null"
    ],
    "scripts": {
      "sync-nix-apps": [
        "$(devbox global path)/scripts/sync-nix-apps.sh"
      ]
    }
  }
}
